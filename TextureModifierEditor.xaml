<?xml version="1.0" encoding="utf-8"?>
<frostyControls:FrostyAssetEditor
    x:Class="FrostyTextureModifier.TextureModifierEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:frostyControls="clr-namespace:Frosty.Core.Controls;assembly=FrostyControls"
    xmlns:local="clr-namespace:FrostyTextureModifier">

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="350" />
        </Grid.ColumnDefinitions>

        <!-- Texture Preview Viewport -->
        <Grid Grid.Column="0" Background="#252526">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Toolbar with Modify TextureAsset Button -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#3E3E42" Padding="5">
                <Button Name="ModifyTextureAssetBtn" Click="OnModifyTextureAssetClick" 
                        Width="150" Height="35" Margin="5" Background="#007ACC" Foreground="White" FontWeight="Bold">
                    Modify TextureAsset
                </Button>
                <Button Name="ResetBtn" Click="OnResetClick" 
                        Width="100" Height="35" Margin="5" Background="#6A6A6A" Foreground="White">
                    Reset
                </Button>
                <Button Name="SaveBtn" Click="OnSaveClick" 
                        Width="100" Height="35" Margin="5" Background="#107C10" Foreground="White">
                    Save
                </Button>
            </StackPanel>

            <!-- Viewport Image Display -->
            <Image Name="TexturePreview" Grid.Row="1" Stretch="UniformToFill" />
        </Grid>

        <!-- Control Panel -->
        <ScrollViewer Grid.Column="1" Background="#252526" VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Padding="10">

                <!-- Title -->
                <TextBlock Text="Color Modifier" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />

                <!-- Mode Selection -->
                <TextBlock Text="Modification Mode" Foreground="#CCCCCC" FontSize="12" Margin="0,10,0,5" />
                <ComboBox Name="ModeModeComboBox" Background="#3C3C3C" Foreground="White" Padding="5" SelectionChanged="OnModeChanged" Margin="0,0,0,10" />

                <!-- Original Color Selection -->
                <TextBlock Text="Original Color" Foreground="#CCCCCC" FontSize="12" Margin="0,10,0,5" />
                <Button Name="PickOriginalColorBtn" Click="OnPickOriginalColorClick" 
                        Width="100" Height="30" Margin="0,0,0,10" Background="#007ACC" Foreground="White">
                    Pick Color
                </Button>
                <Rectangle Name="OriginalColorDisplay" Height="40" Margin="0,0,0,10" Fill="#FF0000" Stroke="#FFFFFF" StrokeThickness="1" />
                <TextBlock Name="OriginalColorText" Text="#FF0000" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,10" />

                <!-- Tolerance Slider -->
                <TextBlock Text="Color Tolerance" Foreground="#CCCCCC" FontSize="12" Margin="0,10,0,5" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Slider Name="ToleranceSlider" Grid.Column="0" Minimum="0" Maximum="100" Value="15" 
                            Background="#3C3C3C" Foreground="#007ACC" VerticalAlignment="Center" />
                    <TextBlock Name="ToleranceValue" Grid.Column="1" Text="15%" Foreground="#CCCCCC" 
                               FontSize="11" TextAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <!-- New Color Selection -->
                <TextBlock Text="New Color" Foreground="#CCCCCC" FontSize="12" Margin="0,10,0,5" />
                <Button Name="PickNewColorBtn" Click="OnPickNewColorClick" 
                        Width="100" Height="30" Margin="0,0,0,10" Background="#007ACC" Foreground="White">
                    Pick Color
                </Button>
                <Rectangle Name="NewColorDisplay" Height="40" Margin="0,0,0,10" Fill="#00FF00" Stroke="#FFFFFF" StrokeThickness="1" />
                <TextBlock Name="NewColorText" Text="#00FF00" Foreground="#CCCCCC" FontSize="11" Margin="0,0,0,10" />

                <!-- HSV Adjustment (for non-replace modes) -->
                <TextBlock Name="HSVLabel" Text="HSV Adjustments" Foreground="#CCCCCC" FontSize="12" Margin="0,10,0,5" Visibility="Collapsed" />

                <!-- Hue -->
                <TextBlock Text="Hue" Foreground="#CCCCCC" FontSize="11" Margin="0,5,0,2" />
                <Slider Name="HueSlider" Minimum="-180" Maximum="180" Value="0" 
                        Background="#3C3C3C" Foreground="#FF6B6B" Margin="0,0,0,8" Visibility="Collapsed" />

                <!-- Saturation -->
                <TextBlock Text="Saturation" Foreground="#CCCCCC" FontSize="11" Margin="0,5,0,2" />
                <Slider Name="SaturationSlider" Minimum="-100" Maximum="100" Value="0" 
                        Background="#3C3C3C" Foreground="#4EC9B0" Margin="0,0,0,8" Visibility="Collapsed" />

                <!-- Brightness -->
                <TextBlock Text="Brightness" Foreground="#CCCCCC" FontSize="11" Margin="0,5,0,2" />
                <Slider Name="BrightnessSlider" Minimum="-100" Maximum="100" Value="0" 
                        Background="#3C3C3C" Foreground="#DCDCAA" Margin="0,0,0,8" Visibility="Collapsed" />

                <!-- Contrast -->
                <TextBlock Text="Contrast" Foreground="#CCCCCC" FontSize="11" Margin="0,5,0,2" />
                <Slider Name="ContrastSlider" Minimum="-100" Maximum="100" Value="0" 
                        Background="#3C3C3C" Foreground="#CE9178" Margin="0,0,0,20" Visibility="Collapsed" />

                <!-- Action Buttons -->
                <Button Name="ApplyBtn" Click="OnApplyClick" 
                        Width="120" Height="35" Margin="0,10" Background="#107C10" Foreground="White" FontWeight="Bold">
                    Apply Changes
                </Button>
                <Button Name="PreviewBtn" Click="OnPreviewClick" 
                        Width="120" Height="35" Margin="0,5" Background="#0078D4" Foreground="White">
                    Preview
                </Button>

                <!-- History Section -->
                <TextBlock Text="History" Foreground="#CCCCCC" FontSize="12" Margin="0,20,0,5" FontWeight="Bold" />
                <ListBox Name="HistoryListBox" Height="100" Background="#1E1E1E" Foreground="#CCCCCC" 
                         BorderBrush="#3C3C3C" BorderThickness="1" Margin="0,0,0,10" />

                <!-- Undo/Redo Buttons -->
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Name="UndoBtn" Click="OnUndoClick" Grid.Column="0" 
                            Height="30" Margin="0,0,5,0" Background="#6A6A6A" Foreground="White">
                        Undo
                    </Button>
                    <Button Name="RedoBtn" Click="OnRedoClick" Grid.Column="1" 
                            Height="30" Margin="5,0,0,0" Background="#6A6A6A" Foreground="White">
                        Redo
                    </Button>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</frostyControls:FrostyAssetEditor>
